# Variables de entorno para la aplicación
# Copiar este archivo a .env y configurar los valores

# === MongoDB ===
# URI de conexión a MongoDB (REQUERIDA)
MONGO_URI=mongodb://localhost:27017/conversor_pdf

# Nombre de la base de datos (default: pdf_db)
MONGO_DATABASE_NAME=pdf_db

# Nombre de la colección de PDFs (default: pdfs)
MONGO_COLLECTION_NAME=pdfs

# === Application Server ===
# Título de la aplicación (default: Proyecto Convertidor - API Conversor PDF)
APP_TITLE=Proyecto Convertidor - API Conversor PDF

# Host del servidor (default: 0.0.0.0)
APP_HOST=0.0.0.0

# Puerto del servidor (default: 8000)
APP_PORT=8000

# === Upload Configuration ===
# Tamaño máximo de archivo en MB (default: 50)
MAX_FILE_SIZE_MB=50

# Extensión de archivo permitida (default: .pdf)
ALLOWED_FILE_EXTENSION=.pdf
